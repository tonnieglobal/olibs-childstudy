rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'anthonyossy@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- VALIDATION BLUEPRINTS ---
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email == request.auth.token.email
        && data.role in ['parent', 'tutor', 'admin', 'manager', 'support']
        && (data.displayName is string && data.displayName.size() <= 100)
        && (data.photoURL is string && data.photoURL.size() <= 500);
    }

    function isValidTutorProfile(data) {
      return data.userId == request.auth.uid
        && (data.bio is string && data.bio.size() <= 5000)
        && (data.pricing is number && data.pricing >= 0 && data.pricing <= 100000)
        && (data.specialization is list && data.specialization.size() <= 20);
    }

    function isValidLesson(data) {
      return data.subject is string && data.subject.size() <= 100
        && data.childName is string && data.childName.size() <= 100
        && data.status in ['scheduled', 'completed', 'cancelled', 'trial']
        && data.durationMinutes is number && data.durationMinutes > 0;
    }

    // --- CATCH-ALL DENY ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- COLLECTIONS ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isOwner(userId) && isValidUser(incoming()) 
        && incoming().role in ['parent', 'tutor']; // Standard users can't self-promote to admin
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().role == existing().role // Role is immutable
        && incoming().isVerified == existing().isVerified; // Approval is system-locked
      allow delete: if isAdmin();
    }

    match /tutors/{tutorId} {
      allow read: if true; // Public tutor directory
      allow create: if isVerified() && isOwner(tutorId) && isValidTutorProfile(incoming())
        && incoming().isApproved == false; // Must be pending
      allow update: if (isOwner(tutorId) && isValidTutorProfile(incoming()) 
          && incoming().isApproved == existing().isApproved) // Can't self-approve
        || isAdmin();
      allow delete: if isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if isSignedIn() && (
        isOwner(existing().parentUid) || isOwner(existing().tutorUid) || isAdmin()
      );
      allow create: if isVerified() && isOwner(incoming().parentUid) && isValidLesson(incoming());
      allow update: if isSignedIn() && (
        (isOwner(existing().parentUid) && isValidLesson(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'subject', 'childName'])) ||
        (isOwner(existing().tutorUid) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'recordingUrl', 'report'])) ||
        isAdmin()
      );
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isVerified() && isOwner(incoming().reviewerUid) 
        && incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5
        && (incoming().comment is string && incoming().comment.size() <= 1000);
      allow delete: if isAdmin() || isOwner(existing().reviewerUid);
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(existing().userId);
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isOwner(existing().userId);
    }
  }
}
